#!/usr/bin/env bash
set -euo pipefail

CONFIG=/etc/rclone/rclone.conf
SOURCE=/srv/stream-rec/downloads
DEST=r2:stream-rec-recordings
LOG=/srv/stream-rec/logs/r2-upload.log
MIN_AGE_MINUTES=10

mkdir -p "$(dirname "$LOG")"

if [ ! -s "$CONFIG" ]; then
  echo "$(date -Is) rclone config missing: $CONFIG" >> "$LOG"
  exit 0
fi

if ! command -v fuser >/dev/null 2>&1; then
  echo "$(date -Is) fuser missing; refusing to upload without open-file protection" >> "$LOG"
  exit 0
fi

UPLOAD_FILES=$(mktemp)
trap 'rm -f "$UPLOAD_FILES"' EXIT

while IFS= read -r -d '' file; do
  if fuser -s "$file" 2>/dev/null; then
    echo "$(date -Is) skip open file: ${file#$SOURCE/}" >> "$LOG"
    continue
  fi

  printf '%s\n' "${file#$SOURCE/}" >> "$UPLOAD_FILES"
done < <(find "$SOURCE" -type f -mmin +"$MIN_AGE_MINUTES" -print0)

if [ ! -s "$UPLOAD_FILES" ]; then
  echo "$(date -Is) no closed files older than ${MIN_AGE_MINUTES}m" >> "$LOG"
  exit 0
fi

rclone move "$SOURCE" "$DEST" \
  --config "$CONFIG" \
  --files-from "$UPLOAD_FILES" \
  --transfers 2 \
  --checkers 4 \
  --delete-empty-src-dirs \
  --log-file "$LOG" \
  --log-level INFO
